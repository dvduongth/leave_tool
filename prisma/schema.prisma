generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  MANAGER
  HEAD
  ADMIN
}

enum ShiftType {
  A
  B
  C
  D
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum LeaveStatus {
  DRAFT
  PENDING_MANAGER
  PENDING_HEAD
  APPROVED
  REJECTED
  CANCEL_PENDING
  CANCELLED
}

enum ApprovalAction {
  APPROVED
  REJECTED
  AUTO_APPROVED
}

enum RecordStatus {
  PENDING
  APPROVED
  REJECTED
  CANCEL_PENDING
  CANCELLED
}

enum FlexType {
  DEFICIT
  MAKEUP
}

enum FlexMonthStatus {
  OPEN
  SETTLED
}

enum MaternityMode {
  EARLY_LEAVE
  LATE_ARRIVAL
}

enum MenstrualMode {
  SHORT
  MEDIUM
  LONG
}

model Department {
  id        String     @id @default(uuid())
  name      String
  headId    String?    @map("head_id")
  head      Employee?  @relation("DepartmentHead", fields: [headId], references: [id])
  employees Employee[] @relation("DepartmentEmployees")

  @@map("departments")
}

model Employee {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  password            String
  departmentId        String    @map("department_id")
  managerId           String?   @map("manager_id")
  role                Role      @default(EMPLOYEE)
  workShift           ShiftType @default(A) @map("work_shift")
  preferredLocale     String    @default("vi") @map("preferred_locale")
  joinDate            DateTime? @map("join_date") @db.Date
  birthDate           DateTime? @map("birth_date") @db.Date
  phone               String?
  gender              Gender    @default(UNSPECIFIED)
  emailNotifEnabled   Boolean   @default(true) @map("email_notif_enabled")
  isActive            Boolean   @default(true) @map("is_active")
  mustChangePassword  Boolean   @default(true) @map("must_change_password")
  createdAt           DateTime  @default(now()) @map("created_at")

  department         Department             @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  manager            Employee?              @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates       Employee[]             @relation("ManagerSubordinates")
  headOfDepartments  Department[]           @relation("DepartmentHead")
  leaveBalances      LeaveBalance[]
  leaveRequests      LeaveRequest[]
  leaveHistoryActor  LeaveRequestHistory[]  @relation("HistoryActor")
  otRecords          OTRecord[]
  otBalances         OTBalance[]
  flexTimeRecords    FlexTimeRecord[]
  flexTimeApprovals  FlexTimeRecord[]       @relation("FlexApprover")
  flexMonthlySummary FlexTimeMonthlySummary[]
  notifications      Notification[]
  menstrualLeaves    MenstrualLeave[]
  weekShifts         EmployeeWeekShift[]
  shiftChangeRequests ShiftChangeRequest[]
  shiftApprovals      ShiftChangeRequest[]   @relation("ShiftApprover")
  children            EmployeeChild[]
  childApprovals      EmployeeChild[]        @relation("ChildApprover")
  maternityLeaves     MaternityLeave[]
  maternityApprovals  MaternityLeave[]       @relation("MaternityApprover")
  auditLogs           AuditLog[]
  fridayOverrides     FridayOverride[]       @relation("FridayOverrideCreator")

  @@map("employees")
}

model LeaveBalance {
  id            String   @id @default(uuid())
  employeeId    String   @map("employee_id")
  cycleYear     Int      @map("cycle_year")
  cycleStart    DateTime @map("cycle_start") @db.Date
  cycleEnd      DateTime @map("cycle_end") @db.Date
  totalHours    Float    @default(96.0) @map("total_hours")
  usedHours     Float    @default(0) @map("used_hours")
  pendingHours  Float    @default(0) @map("pending_hours")
  graceDeadline DateTime @map("grace_deadline") @db.Date

  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]

  @@unique([employeeId, cycleYear])
  @@map("leave_balances")
}

model LeaveRequest {
  id                String          @id @default(uuid())
  employeeId        String          @map("employee_id")
  balanceId         String?         @map("balance_id")
  startDate         DateTime        @map("start_date") @db.Date
  startTime         String          @map("start_time")
  endDate           DateTime        @map("end_date") @db.Date
  endTime           String          @map("end_time")
  totalHours        Float           @map("total_hours")
  otConsumedMinutes Int             @default(0) @map("ot_consumed_minutes")
  reason            String?
  status            LeaveStatus     @default(DRAFT)
  isAutoDeduct      Boolean         @default(false) @map("is_auto_deduct")
  managerAction     ApprovalAction? @map("manager_action")
  managerComment    String?         @map("manager_comment")
  managerActionAt   DateTime?       @map("manager_action_at")
  headAction        ApprovalAction? @map("head_action")
  headComment       String?         @map("head_comment")
  headActionAt      DateTime?       @map("head_action_at")
  cancelledAt       DateTime?       @map("cancelled_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  employee       Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  balance        LeaveBalance?         @relation(fields: [balanceId], references: [id])
  history        LeaveRequestHistory[]
  otConsumptions LeaveOTConsumption[]

  @@index([employeeId, status])
  @@index([status])
  @@map("leave_requests")
}

model LeaveRequestHistory {
  id        String   @id @default(uuid())
  requestId String   @map("request_id")
  action    String
  actorId   String   @map("actor_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  createdAt DateTime @default(now()) @map("created_at")

  request LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   Employee     @relation("HistoryActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("leave_request_history")
}

model OTRecord {
  id          String       @id @default(uuid())
  employeeId  String       @map("employee_id")
  date        DateTime     @db.Date
  otStart     String       @map("ot_start")
  otEnd       String       @map("ot_end")
  otMinutes   Int          @map("ot_minutes")
  note        String?
  status      RecordStatus @default(PENDING)
  otBalanceId String?      @map("ot_balance_id")
  createdAt   DateTime     @default(now()) @map("created_at")

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  otBalance OTBalance? @relation(fields: [otBalanceId], references: [id])

  @@index([employeeId, date])
  @@map("ot_records")
}

model OTBalance {
  id             String   @id @default(uuid())
  employeeId     String   @map("employee_id")
  cycleYear      Int      @map("cycle_year")
  cycleStart     DateTime @map("cycle_start") @db.Date
  cycleEnd       DateTime @map("cycle_end") @db.Date
  graceDeadline  DateTime @map("grace_deadline") @db.Date
  totalMinutes   Int      @default(0) @map("total_minutes")
  usedMinutes    Int      @default(0) @map("used_minutes")
  pendingMinutes Int      @default(0) @map("pending_minutes")
  createdAt      DateTime @default(now()) @map("created_at")

  employee     Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  otRecords    OTRecord[]
  consumptions LeaveOTConsumption[]

  @@unique([employeeId, cycleYear])
  @@index([employeeId, cycleStart, cycleEnd])
  @@map("ot_balances")
}

model LeaveOTConsumption {
  id             String   @id @default(uuid())
  leaveRequestId String   @map("leave_request_id")
  otBalanceId   String   @map("ot_balance_id")
  minutes        Int
  createdAt      DateTime @default(now()) @map("created_at")

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  otBalance    OTBalance    @relation(fields: [otBalanceId], references: [id], onDelete: Cascade)

  @@index([leaveRequestId])
  @@index([otBalanceId])
  @@map("leave_ot_consumptions")
}

model FlexTimeRecord {
  id         String       @id @default(uuid())
  employeeId String       @map("employee_id")
  type       FlexType
  date       DateTime     @db.Date
  minutes    Int
  reason     String?
  status     RecordStatus @default(PENDING)
  approvedBy String?      @map("approved_by")
  createdAt  DateTime     @default(now()) @map("created_at")

  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approver Employee? @relation("FlexApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([employeeId, date])
  @@map("flex_time_records")
}

model FlexTimeMonthlySummary {
  id              String          @id @default(uuid())
  employeeId      String          @map("employee_id")
  yearMonth       String          @map("year_month")
  totalDeficit    Int             @default(0) @map("total_deficit")
  totalMakeup     Int             @default(0) @map("total_makeup")
  remaining       Int             @default(0)
  autoDeductHours Float?          @map("auto_deduct_hours")
  status          FlexMonthStatus @default(OPEN)
  settledAt       DateTime?       @map("settled_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, yearMonth])
  @@map("flex_time_monthly_summaries")
}

model Holiday {
  id   String   @id @default(uuid())
  date DateTime @db.Date
  name String
  year Int

  @@unique([date])
  @@map("holidays")
}

model MenstrualLeave {
  id         String        @id @default(uuid())
  employeeId String        @map("employee_id")
  date       DateTime      @db.Date
  startTime  String        @map("start_time")
  endTime    String        @map("end_time")
  mode       MenstrualMode @default(SHORT)
  note       String?
  createdAt  DateTime      @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@map("menstrual_leaves")
}

model EmployeeWeekShift {
  id            String    @id @default(uuid())
  employeeId    String    @map("employee_id")
  dayOfWeek     Int       @map("day_of_week")
  shiftType     ShiftType @map("shift_type")
  effectiveDate DateTime  @map("effective_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek, effectiveDate])
  @@index([employeeId, effectiveDate])
  @@map("employee_week_shifts")
}

model ShiftChangeRequest {
  id             String       @id @default(uuid())
  employeeId     String       @map("employee_id")
  effectiveDate  DateTime     @map("effective_date") @db.Date
  weeklyShifts   Json         @map("weekly_shifts")
  reason         String?
  status         RecordStatus @default(PENDING)
  approvedBy     String?      @map("approved_by")
  approvedAt     DateTime?    @map("approved_at")
  managerComment String?      @map("manager_comment")
  createdAt      DateTime     @default(now()) @map("created_at")

  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approver Employee? @relation("ShiftApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([employeeId, status])
  @@map("shift_change_requests")
}

model EmployeeChild {
  id         String       @id @default(uuid())
  employeeId String       @map("employee_id")
  birthDate  DateTime     @map("birth_date") @db.Date
  name       String?
  status     RecordStatus @default(PENDING)
  approvedBy String?      @map("approved_by")
  approvedAt DateTime?    @map("approved_at")
  note       String?
  createdAt  DateTime     @default(now()) @map("created_at")

  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approver        Employee?        @relation("ChildApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  maternityLeaves MaternityLeave[]

  @@index([employeeId, birthDate])
  @@map("employee_children")
}

model MaternityLeave {
  id         String        @id @default(uuid())
  employeeId String        @map("employee_id")
  childId    String        @map("child_id")
  date       DateTime      @db.Date
  mode       MaternityMode
  startTime  String        @map("start_time")
  endTime    String        @map("end_time")
  note       String?
  status     RecordStatus  @default(PENDING)
  approvedBy String?       @map("approved_by")
  approvedAt DateTime?     @map("approved_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  child    EmployeeChild @relation(fields: [childId], references: [id], onDelete: Cascade)
  approver Employee?     @relation("MaternityApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@map("maternity_leaves")
}

model AppConfig {
  key         String   @id
  value       String
  type        String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  entity    String?
  entityId  String?  @map("entity_id")
  createdAt DateTime @default(now()) @map("created_at")

  user Employee @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([entity, entityId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user Employee? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model FridayOverride {
  id        String   @id @default(uuid())
  weekStart DateTime @db.Date
  note      String?
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  creator Employee @relation("FridayOverrideCreator", fields: [createdBy], references: [id])

  @@unique([weekStart])
  @@map("friday_overrides")
}
